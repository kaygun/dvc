#!/bin/bash
set -euo pipefail
DVC_DIR=".dvc" REGISTRY="$DVC_DIR/registry" VAULT="$DVC_DIR/vault"

die() { echo "Error: $1" >&2; exit 1; }

usage() { cat <<'EOF'
Usage: dvc <command> [<args>]
Commands:
  init                  Initialise DVC tracking in the current directory
  register <file>       Save the current version of <file>
  checkout <file> <rev> Restore <file> to revision <rev> (prefix of MD5)
  explain <file> <rev>  Show diff between <rev> and its parent
  log <file>            Show commit history of <file>
  graph <file>          Draw ASCII history graph of <file>
EOF
exit 1; }

latest_signature() { grep "^[^ ]* $1 " "$REGISTRY" 2>/dev/null | tail -1 | awk '{print $3}' || true; }

resolve_rev() {
    local matches=("$VAULT/$2"*)
    [[ ${#matches[@]} -eq 0 ]] && die "no revision matches prefix '$2'."
    [[ ${#matches[@]} -gt 1 ]] && die "ambiguous prefix '$2' matches multiple revisions."
    _resolved="${matches[0]}"
}

init() {
    [[ -d "$DVC_DIR" ]] && die "DVC already initialised in this directory."
    mkdir -p "$VAULT"; touch "$REGISTRY"
    echo "Initialised empty DVC repository in $PWD/$DVC_DIR"
}

register() {
    local file="$1"; [[ -f "$file" ]] || die "file '$file' not found."
    local new_sig; new_sig=$(md5sum "$file" | cut -d' ' -f1)
    [[ -n "$new_sig" ]] || die "could not compute MD5 of '$file'."
    local parent_sig; parent_sig=$(latest_signature "$file")
    [[ -n "$parent_sig" && "$new_sig" == "$parent_sig" ]] && { echo "No changes in '$file' since the last registration."; return; }
    local ts; ts=$(date +"%F-%T")
    echo "$ts $file $new_sig $parent_sig" >> "$REGISTRY"
    cp "$file" "$VAULT/$new_sig"
    echo "Registered '$file' (signature: $new_sig)"
}

checkout() {
    local file="$1"; [[ -f "$file" ]] || die "file '$file' does not exist."
    resolve_rev "$file" "$2"; local sig; sig=$(basename "$_resolved")
    grep -q "^[^ ]* $file $sig " "$REGISTRY" || die "revision '$sig' is not recorded for file '$file'."
    cp "$_resolved" "$file"
    echo "Checked out '$file' to revision $sig."
}

explain() {
    resolve_rev "$1" "$2"; local sig; sig=$(basename "$_resolved")
    local psig; psig=$(grep "^[^ ]* $1 $sig " "$REGISTRY" | head -1 | awk '{print $4}' || true)
    if [[ -z "$psig" ]]; then echo "This is the root revision (no parent)."
    elif [[ -f "$VAULT/$psig" ]]; then diff -u "$VAULT/$psig" "$_resolved" || true
    else die "parent revision $psig is missing from the vault."; fi
}

log() { echo "History for '$1':"; grep "^[^ ]* $1 " "$REGISTRY" | sort -k1 || true; }

graph() {
    command -v graph-easy &>/dev/null || die "'graph-easy' not found. Install Graph::Easy to use this feature."
    local dot; dot=$(mktemp --tmpdir "dvc-graph-XXXXXX.dot")
    grep "^[^ ]* $1 " "$REGISTRY" | sort -k1 | awk -v f="$1" '
        BEGIN { print "digraph G { node [shape=box];" }
        { if ($4 != "") printf "  \"%s: %s\" -> \"%s: %s\" [label=\"%s\"];\n", f, $4, f, $3, $1
          else printf "  \"%s: %s\" [label=\"%s: %s\\n(%s)\"];\n", f, $3, f, $3, $1 }
        END { print "}" }' > "$dot"
    graph-easy "$dot" --from=graphviz --as=ascii; rm -f "$dot"
}

[[ $# -ge 1 ]] || usage
case "$1" in
    init)       init ;;
    register)   [[ $# -eq 2 ]] || usage; register "$2" ;;
    checkout)   [[ $# -eq 3 ]] || usage; checkout "$2" "$3" ;;
    explain)    [[ $# -eq 3 ]] || usage; explain "$2" "$3" ;;
    log)        [[ $# -eq 2 ]] || usage; log "$2" ;;
    graph)      [[ $# -eq 2 ]] || usage; graph "$2" ;;
    *)          usage ;;
esac
